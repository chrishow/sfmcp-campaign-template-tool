{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "outDir": "./dist",
    "noEmit": false,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "typeRoots": ["./src", "./node_modules/@types"]
  },
  "include": ["src/*.ts", "sfMCP-files/server-side.ts"],
  "exclude": ["node_modules"]
}